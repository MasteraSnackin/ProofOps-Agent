  {
    "id": "workflow-005",
    "scenario": "bad_fit_identity_project",
    "method": "POST",
    "path": "/api/proof/run",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "dealId": "deal-004",
      "trigger": "manual_proof_request",
      "proof_need": "SSO migration reference"
    },
    "expected": {
      "http_status": 200,
      "quality_check": "Low score or weak-fit proof should be obvious in the result."
    }
  },
  {
    "id": "workflow-006",
    "scenario": "inline_deal_payload",
    "method": "POST",
    "path": "/api/proof/run",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "deal": {
        "id": "inline-deal-001",
        "company": "Inline Demo Buyer",
        "stage": "Stalled",
        "value": "GBP 52000",
        "owner": "Demo Owner",
        "stalledDays": 15,
        "segment": "Public sector",
        "useCase": "Document-heavy intake routing",
        "objections": ["legacy systems", "accessibility"],
        "risk": "Buyer wants a same-segment reference.",
        "nextMeeting": "Demo review tomorrow"
      }
    },
    "expected": {
      "http_status": 200,
      "trace_contains": "Accepted inline deal payload"
    }
  },
  {
