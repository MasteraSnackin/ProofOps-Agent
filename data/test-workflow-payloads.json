[
  {
    "id": "workflow-001",
    "scenario": "normal_stalled_deal",
    "method": "POST",
    "path": "/api/attio/workflow",
    "headers": {
      "content-type": "application/json",
      "x-proofops-secret": "dev-secret",
      "idempotency-key": "evt_camden_stalled_001"
    },
    "body": {
      "dealId": "deal-001",
      "trigger": "deal_stalled",
      "events": [
        {
          "event_id": "evt_camden_stalled_001",
          "type": "record.updated",
          "id": {
            "workspace_id": "wrk_test",
            "object_id": "obj_deals",
            "record_id": "rec_deal_camden_icb"
          },
          "data": {
            "object_slug": "deals",
            "record_id": "rec_deal_camden_icb",
            "changed_attribute": "stalled_days"
          }
        }
      ]
    },
    "expected": {
      "http_status": 200,
      "duplicate_suppressed": false,
      "best_match_hint": "Northstar Health Trust"
    }
  },
  {
    "id": "workflow-002",
