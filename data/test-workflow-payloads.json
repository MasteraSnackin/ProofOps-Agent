  {
    "id": "workflow-003",
    "scenario": "missing_webhook_secret",
    "method": "POST",
    "path": "/api/attio/workflow",
    "headers": {
      "content-type": "application/json",
      "idempotency-key": "evt_crownbridge_missing_secret"
    },
    "body": {
      "dealId": "deal-002",
      "trigger": "manual_proof_request"
    },
    "requires_env": {
      "PROOFOPS_WEBHOOK_SECRET": "dev-secret"
    },
    "expected": {
      "http_status": 401,
      "error": "ProofOps webhook secret missing or invalid"
    }
  },
  {
    "id": "workflow-004",
    "scenario": "procurement_security_review",
    "method": "POST",
    "path": "/api/attio/workflow",
    "headers": {
      "content-type": "application/json",
      "authorization": "Bearer dev-secret",
      "idempotency-key": "evt_quarry_security_001"
    },
    "body": {
      "dealId": "deal-003",
      "trigger": "manual_proof_request",
      "requested_by": "Noor Ahmed",
